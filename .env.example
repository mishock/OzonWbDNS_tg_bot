# Что: имя приложения.
# Зачем: используется в логах и служебной идентификации.
APP_NAME=ozon-wb-dns-bot
# Что: окружение запуска.
# Зачем: задел под dev/prod-поведение.
APP_ENV=dev
# Что: служебный порт приложения.
# Важно: при polling напрямую Telegram не используется, но оставлен для стандарта.
APP_PORT=8000
# Что: токен Telegram-бота из @BotFather.
# Важно: держать в секрете, не публиковать.
TELEGRAM_BOT_TOKEN=PUT_TELEGRAM_BOT_TOKEN_HERE
# Что: основной токен для aiogram-приложения.
# Зачем: новый код читает BOT_TOKEN в первую очередь.
BOT_TOKEN=PUT_TELEGRAM_BOT_TOKEN_HERE
# Что: API-ключ DeepSeek.
# Зачем: диалоговый ответ и анализ поискового намерения.
# Важно: хранить как секрет.
DEEPSEEK_API_KEY=PUT_DEEPSEEK_API_KEY_HERE
# Что: базовый URL DeepSeek API.
# Зачем: можно переключить endpoint без правки кода.
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Что: имя модели DeepSeek.
# Зачем: используется и для диалога, и для нормализации поискового запроса.
DEEPSEEK_MODEL=deepseek-chat
# Что: глобальный переключатель AI-рекомендаций.
# Важно: false полностью отключает обращения к DeepSeek.
AI_ENABLED=true
