# Что: исключения из git.
# Зачем: хранить в репозитории только исходники и документацию.

# Что: кеш и артефакты Python.
__pycache__/
*.pyc
*.pyo
*.pyd

# Что: локальные virtualenv-окружения.
.venv/
venv/

# Что: секреты и токены.
# Важно: .env не должен попадать в git.
.env

# Что: IDE-специфичные файлы.
.idea/
.vscode/
.cursorrules
CHANGELOG.md
