# Что: базовый рантайм с Python 3.11.
# Зачем: стабильная версия интерпретатора для бота.
# Важно: slim-образ уменьшает размер итогового контейнера.
FROM python:3.11-slim-bookworm

# Что: рабочая директория внутри контейнера.
# Зачем: все дальнейшие команды выполняются из /app.
WORKDIR /app

# Что: копируем только файл зависимостей.
# Зачем: ускоряем пересборку за счет кэша слоев Docker.
COPY requirements.txt .
# Что: установка зависимостей проекта.
# Зачем: подготовить окружение для запуска бота.
# Важно: слой переиспользуется, пока не меняется requirements.txt.
RUN pip install --no-cache-dir -r requirements.txt

# Что: копируем исходный код проекта.
# Зачем: контейнер получает актуальную версию приложения.
COPY . .

# Что: команда запуска контейнера.
# Зачем: стартует основной процесс Telegram-бота.
# Важно: можно переопределить через docker-compose.yml -> command.
CMD ["python", "main.py"]
