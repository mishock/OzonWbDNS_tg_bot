# Что: исключения из docker build context.
# Зачем: ускорить сборку и не передавать лишние/секретные файлы в Docker.

# Что: служебные git-артефакты.
.git
.gitignore

# Что: кеш/байткод Python.
__pycache__/
*.pyc
*.pyo
*.pyd

# Что: локальные virtualenv.
# Важно: не должны попадать в образ.
.venv/
venv/

# Что: секреты приложения.
# Важно: .env никогда не отправляем в build context.
.env
